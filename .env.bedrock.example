# Claude Provider Configuration
# Use "anthropic" for Anthropic API or "bedrock" for AWS Bedrock
CLAUDE_PROVIDER=bedrock

# AWS Bedrock Configuration (if CLAUDE_PROVIDER=bedrock)
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL=anthropic.claude-sonnet-4-20250514-v1:0

# AWS Credentials (Optional - boto3 will use ~/.aws/credentials if not set)
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Anthropic API Configuration (if CLAUDE_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Server Ports
PORT_MCP=8001
PORT_AGENT=8000

# MCP Server URL
MCP_SERVER_URL=http://localhost:8001

# FHIR Server
HAPI_FHIR_BASE=https://hapi.fhir.org/baseR4

# HTTP Client
HTTP_CONNECT_TIMEOUT=10.0
HTTP_READ_TIMEOUT=30.0
HTTP_MAX_RETRIES=3

# Task Store
TASK_TTL_HOURS=24
MAX_CONCURRENT_TASKS=10

# Claude API Settings
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.0

# Orchestrator
MAX_TOOL_ITERATIONS=10
ORCHESTRATOR_TIMEOUT=60.0

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=development
